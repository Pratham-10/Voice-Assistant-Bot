# Gemini API Key (Required for ChatGPT-like chat and generation functionalities)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (Required for weather updates)
WEATHER_API_KEY=your_openweathermap_api_key_here

# Default local path to play music (optional, defaults to empty or user download path)
MUSIC_PATH=
