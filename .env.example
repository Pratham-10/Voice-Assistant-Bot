# Gemini API Key (Required for ChatGPT-like chat and generation functionalities)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (Required for weather updates)
WEATHER_API_KEY=your_openweathermap_api_key_here

# Spotify Credentials (Required for Spotify integration)
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Google API Credentials JSON file path (Required for Google Calendar & Gmail integration)
GOOGLE_CREDENTIALS_PATH=credentials.json

